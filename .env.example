# SGU Admission Counselor - Environment Variables
# Copy this file to .env and fill in the actual values

# ===== REQUIRED =====
GEMINI_API_KEY=your_gemini_api_key_here

# ===== OPTIONAL (will use defaults if not set) =====

# Model Configuration
GEMINI_MODEL=gemini-2.5-flash
WHISPER_MODEL_SIZE=small.en
WHISPER_LANGUAGE=en
TTS_VOICE=en-US-Female

# RAG Configuration
RAG_TOP_K=3
RAG_THRESHOLD=0.15
MAX_CONTEXT_CHARS=1600
CACHE_THRESHOLD=0.90

# Microphone Configuration
# MIC_DEVICE_INDEX=0  # Uncomment and set if you have multiple microphones

# Timeouts
LISTEN_TIMEOUT_SEC=8
PHRASE_TIME_LIMIT_SEC=12
AMBIENT_CALIBRATION_SEC=1.0

# Debug Mode
RAG_DEBUG=1

# Server ports (optional - used by api_server.py and React)
FLASK_PORT=5000
REACT_PORT=5173
